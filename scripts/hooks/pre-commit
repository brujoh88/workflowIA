#!/bin/sh
# pre-commit hook: Quality validation before commits
# Checks: lint (if configured), TypeScript errors (if tsc available), file size (R4)
# Bypass: git commit --no-verify (emergencies only)

CONFIG_FILE=".claude/project.config.json"

# Read config (fallback to defaults if jq not available)
if command -v jq >/dev/null 2>&1 && [ -f "$CONFIG_FILE" ]; then
  LINT_CMD=$(jq -r '.commands.lint // ""' "$CONFIG_FILE")
  MAX_LINES=$(jq -r '.workflow.maxFileLines // 400' "$CONFIG_FILE")
else
  LINT_CMD=""
  MAX_LINES=400
fi

# Check 1: Lint (if configured and command exists)
if [ -n "$LINT_CMD" ]; then
  echo "pre-commit: Running lint..."
  eval "$LINT_CMD" 2>/dev/null
  if [ $? -ne 0 ]; then
    echo "pre-commit: Lint failed. Fix issues or use --no-verify to bypass."
    exit 1
  fi
fi

# Check 2: File size (R4)
OVERSIZED=""
for file in $(git diff --cached --name-only --diff-filter=ACM); do
  if [ -f "$file" ]; then
    lines=$(wc -l < "$file")
    if [ "$lines" -gt "$MAX_LINES" ]; then
      OVERSIZED="$OVERSIZED\n  $file ($lines lines, max $MAX_LINES)"
    fi
  fi
done
if [ -n "$OVERSIZED" ]; then
  echo "pre-commit: Files exceed max line limit (R4):$OVERSIZED"
  echo "Split files or use --no-verify to bypass."
  exit 1
fi

# Check 3: TypeScript errors (R16, if tsc available)
if command -v npx >/dev/null 2>&1 && [ -f "tsconfig.json" ]; then
  echo "pre-commit: Checking TypeScript..."
  npx tsc --noEmit 2>/dev/null
  if [ $? -ne 0 ]; then
    echo "pre-commit: TypeScript errors found (R16). Fix before committing."
    exit 1
  fi
fi

echo "pre-commit: All checks passed."
